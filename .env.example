# Copy this file to `.env.local` for local development.
# Put your real server-side secrets there. Never expose these in frontend code.

OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=

# Infrastructure
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/storyflow_studio?schema=public"
REDIS_URL="redis://localhost:6379"

# Local storage/output paths used by workers and FFmpeg
MEDIA_ROOT="./storage"
FFMPEG_PATH="ffmpeg"
