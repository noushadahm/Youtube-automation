# Copy this file to `.env.local` for local development.
# All secrets below are server-only except the NEXT_PUBLIC_* vars.

# ----- AI providers -----
OPENAI_API_KEY=
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# ----- Supabase -----
# Found under Project Settings > API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: storage bucket name used for generated images / audio / video.
# Create this bucket (private) in Supabase Storage before first use.
SUPABASE_STORAGE_BUCKET=sf-media

# ----- Prisma / Postgres (Supabase) -----
# Get the password from: Supabase dashboard > Project Settings > Database.
# Use the "Transaction" pooler URL (port 6543) as DATABASE_URL,
# and the "Session" / direct URL (port 5432) as DIRECT_URL for migrations.
# Example (replace placeholders):
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
DATABASE_URL=
DIRECT_URL=

# ----- Local runtime -----
# MEDIA_ROOT is ephemeral scratch space for FFmpeg; persistent media goes to
# Supabase Storage (see SUPABASE_STORAGE_BUCKET).
MEDIA_ROOT=/tmp/storyflow
FFMPEG_PATH=ffmpeg

# ----- Redis (BullMQ worker queue) -----
# Install Redis locally (brew/apt) or run `docker compose up -d`.
REDIS_URL=redis://127.0.0.1:6379
